{
  "version": 2,
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "includeFiles": ["../dist/**", "../prisma/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/api/index.js" }]
}
