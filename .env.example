# Prisma: for Supabase use DIRECT for migrations, POOLER for app (or same URL for dev).
# Direct (required for `prisma migrate`): postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Pooler (optional, for app): postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgres://user:password@host:5432/dbname
DIRECT_DATABASE_URL=postgres://user:password@host:5432/dbname

SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Base URL without /auth/v1 (client adds it)
SUPABASE_URL=https://your-project-id.supabase.co
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key
PORT=3000
NODE_ENV=development
